# Hermeneia — configuration (all optional)

# Port for the QR code setup page (default: 3456)
HERMENEIA_QR_PORT=3456

# Data directory for SQLite + auth (default: ./data next to the script)
# HERMENEIA_DATA_DIR=/path/to/data

# Webhook URL for incoming messages (optional)
# WEBHOOK_URL=http://localhost:8769/whatsapp/webhook
